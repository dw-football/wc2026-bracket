# Secrets — never commit
.env
*.key

# Personal calendar binding + generated apply plan (never commit David's IDs)
calendar-map.local.json
calendar-sync-plan.json

# Node
node_modules/

# Unattended auto-sync local state (processed set tracker) + tick log
autosync-state.json
autosync.log

# Machine-specific launcher (real paths + OAuth env); use run-autosync.example.cmd
run-autosync.cmd

# Build artifacts / cached API pulls
data/raw/
dist/exports/
dist/baked-mc.json
*.log
# NOTE: data/match-events.json (ESPN events cache) is COMMITTED on purpose — the
# build bakes it into the page, and the unattended auto-sync rebuild on main has no
# other copy, so gitignoring it would silently drop the match-detail popovers.

# Throwaway analysis drills (3rd-place / Scotland qualifying scratch; not kept)
par_drill*.mjs
sco_*.mjs
third_dist.mjs
